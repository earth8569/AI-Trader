# OKX API credentials — DO NOT COMMIT a real version of this file.
# Copy to .env and fill. The code auto-loads .env at import time (see src/live/okx_auth.py).
# You can also export them manually:
#   source .env        (bash / WSL)
#   Get-Content .env | ForEach-Object { if ($_ -match '^([^=#][^=]*)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim('"').Trim()) } }   (PowerShell)

# Mint these in OKX -> "Demo Trading" -> API Management (NOT the live API key page).
OKX_API_KEY=your-demo-api-key
OKX_API_SECRET=your-demo-api-secret
OKX_API_PASSPHRASE=your-demo-passphrase

# Safety flags
OKX_DEMO=1           # 1 = simulated trading, 0 = live (real money)
# OKX_ENABLE_LIVE=1   # ALSO required before OKX_DEMO=0 will be honored
